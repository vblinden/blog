package errors

import (
	"blog/templates"
	"blog/templates/partials"
)

templ NotFound() {
	@templates.Layout("Page not found") {
		<p>Sorry, but we can't find the page you're looking for.</p>
		<p class="mt-3">
			Click&nbsp;
			@partials.Link("here", templ.Attributes{"href": "/"})
			&nbsp;to return home.
		</p>
	}
}
